---
import type { Props } from "@astrojs/starlight/props";
import Splash from "./Splash.astro";

const { data } = Astro.props.entry;
const { title = data.title, tagline } = data.hero ?? {};
---

<section class="hero">
  <h1 id="_top" class="visually-hidden" data-page-title set:html={title} />

  <div class="hero-splash">
    <Splash />
  </div>

  <div class="hero-wordmark">
    <p class="hero-name">blak.nvim</p>
    <p class="hero-tagline">
      {tagline ?? "Everything useful. Nothing escapes."}
    </p>
  </div>

  <div class="hero-install" aria-label="Install command">
    <span class="hero-install-prompt" aria-hidden="true">$</span>
    <code id="hero-install-cmd">curl -fsSL https://raw.githubusercontent.com/binbandit/blak.nvim/main/install.sh | sh</code>
    <button
      class="hero-install-copy"
      type="button"
      aria-label="Copy install command"
      data-copy="curl -fsSL https://raw.githubusercontent.com/binbandit/blak.nvim/main/install.sh | sh"
    >
      <svg class="icon-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
      </svg>
      <svg class="icon-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="20 6 9 17 4 12" />
      </svg>
    </button>
  </div>

  <div class="hero-actions">
    <a class="hero-btn variant-primary" href="/blak.nvim/start/why/">
      <span>Read the docs</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </a>
    <a class="hero-btn variant-ghost" href="https://github.com/binbandit/blak.nvim">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.25.78-.55v-2.1c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.06 11.06 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.41-5.25 5.69.41.35.78 1.05.78 2.12v3.14c0 .31.21.66.79.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z" />
      </svg>
      <span>GitHub</span>
    </a>
  </div>
</section>

<script>
  (() => {
    const btn = document.querySelector(".hero-install-copy");
    if (!(btn instanceof HTMLButtonElement)) return;
    btn.addEventListener("click", async () => {
      const text = btn.getAttribute("data-copy") || "";
      try {
        await navigator.clipboard.writeText(text);
        btn.setAttribute("data-copied", "1");
        setTimeout(() => btn.removeAttribute("data-copied"), 1400);
      } catch (_) {
        /* ignore */
      }
    });
  })();
</script>
