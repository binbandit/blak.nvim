---
const stack = [
  { role: "Package manager", tool: "lazy.nvim", note: "config rollback included" },
  { role: "Default picker", tool: "fff.nvim", note: "fast, native" },
  { role: "Completion", tool: "blink.cmp", note: null },
  { role: "LSP wiring", tool: "vim.lsp.config()", note: "native, no wrapper" },
  { role: "Formatter", tool: "conform.nvim", note: null },
  { role: "Linter", tool: "nvim-lint", note: null },
  { role: "Treesitter", tool: "nvim-treesitter", note: null },
  { role: "Explorer", tool: "oil.nvim", note: "neo-tree / snacks via extras" },
  { role: "Git signs", tool: "gitsigns.nvim", note: null },
  { role: "Keymap hints", tool: "which-key.nvim", note: "every mapping described" },
  { role: "Dashboard", tool: "Snacks", note: "black-hole splash" },
  { role: "Colorscheme", tool: "blak", note: "monochrome with ember red" },
];
---

<section class="section">
  <header class="section-head">
    <span class="eyebrow">
      <span class="eyebrow-dot" aria-hidden="true"></span>
      <span>// stack</span>
    </span>
    <h2 class="section-title">The default kit.</h2>
    <p class="section-sub">
      Twelve core decisions, wired up and reversible. Anything beyond this set
      lives in an opt-in extra.
    </p>
  </header>

  <table class="kit">
    <caption class="visually-hidden">Default tools shipped with Blak</caption>
    <thead>
      <tr>
        <th scope="col">What it does</th>
        <th scope="col">Tool we ship</th>
      </tr>
    </thead>
    <tbody>
      {stack.map((row) => (
        <tr>
          <th scope="row" class="kit-role">{row.role}</th>
          <td class="kit-tool">
            <span class="kit-tool-name" translate="no">{row.tool}</span>
            {row.note && <span class="kit-tool-note">{row.note}</span>}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</section>
